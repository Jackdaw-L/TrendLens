DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=
DEEPSEEK_THINKING=disabled
DEEPSEEK_MAX_TOKENS=12000
DEEPSEEK_ATTEMPTS=2
DEEPSEEK_TIMEOUT_MS=180000
SUPABASE_URL=https://vbwzcvycobnpohetvjjd.supabase.co
SUPABASE_SECRET_KEY=
MAX_ITEMS_PER_SOURCE=5
FETCH_ATTEMPTS=3
# 抓取与转写并发：source 级并发 / 单 source 内文章级并发 / DeepSeek 逐篇转写并发
FETCH_SOURCE_CONCURRENCY=4
FETCH_ARTICLE_CONCURRENCY=3
REWRITE_CONCURRENCY=2
# Supabase 历史 run 保留天数，过期 run（含其文章与抓取快照）在每次流水线结束时清理；0 关闭
RUNS_RETENTION_DAYS=30
LLM_CANDIDATE_ARTICLES=24
LLM_MAX_ARTICLES=10
# 跨 run 去重：剔除最近 N 天内已推荐过的文章，避免连续两天推荐重复内容；设为 0 关闭
DEDUP_LOOKBACK_DAYS=3
LLM_SELECT_CONTENT_CHARS=900
FRIDAY_REWRITE_ATTEMPTS=3
FRIDAY_REWRITE_CONTENT_CHARS=12000
FRIDAY_REWRITE_MIN_CHINESE_CHARS=800
FRIDAY_MIN_CONTENT_CHARS=400
LLM_SELECT_SYSTEM_PROMPT_PATH=prompts/select-system.md
LLM_SELECT_USER_PROMPT_PATH=prompts/select-user.md
LLM_REWRITE_SYSTEM_PROMPT_PATH=prompts/rewrite-system.md
LLM_REWRITE_USER_PROMPT_PATH=prompts/rewrite-user.md
GITHUB_ACTIONS_TOKEN=
GITHUB_ACTIONS_REPO=Jackdaw-L/TrendLens
GITHUB_ACTIONS_WORKFLOW=daily-pipeline.yml
GITHUB_ACTIONS_REF=main
# 写操作与更新触发共用口令：收藏、信息源管理、已读同步、更新推荐都用它鉴权
TRENDLENS_TRIGGER_SECRET=change-me
TRENDLENS_REVALIDATE_URL=https://trendlensapp.netlify.app/api/revalidate
TRENDLENS_REVALIDATE_TOKEN=
